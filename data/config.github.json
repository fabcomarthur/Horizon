        "enabled": true,
        "category": "ai-model"
      },
      {
        "name": "Google — Ads & Commerce blog",
        "url": "https://blog.google/products/ads-commerce/rss/",
        "enabled": true,
        "category": "ad-platform"
      },
      {
        "name": "ExchangeWire",
        "url": "https://www.exchangewire.com/feed/",
