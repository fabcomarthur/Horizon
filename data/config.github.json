{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 4,
    "languages": [
      "zh",
      "en"
    ],
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Digiday",
        "url": "https://digiday.com/feed/",
        "enabled": true,
        "category": "media-marketing"
      },
      {
        "name": "Marketing Dive",
        "url": "https://www.marketingdive.com/feeds/news/",
        "enabled": true,
        "category": "marketing"
      },
      {
        "name": "PPC Hero",
        "url": "https://feeds.feedburner.com/PpcHero",
        "enabled": true,
        "category": "ppc"
      },
      {
        "name": "Search Engine Journal",
        "url": "https://www.searchenginejournal.com/feed/",
        "enabled": true,
        "category": "search-seo"
      },
      {
        "name": "Search Engine Roundtable",
        "url": "https://www.seroundtable.com/index.rss",
        "enabled": true,
        "category": "search-seo"
      },
      {
        "name": "Social Media Today",
        "url": "https://www.socialmediatoday.com/feeds/news/",
        "enabled": true,
        "category": "social"
      },
      {
        "name": "Simon Willison (AI)",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 8
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "ai": {
        "limit": 6,
        "categories": ["ai-tools", "ai-news", "machine-learning"]
      }
    }
  },
  "webhook": {
    "enabled": false
  }
}
