        "categories": ["ad-platform", "programmatic", "search-ppc"]
      },
      "industry": {
        "limit": 7,
        "categories": ["marketing", "social"]
      },
      "ai": {
        "limit": 4,
        "categories": ["ai-model"]
      }
    }
  },
  "webhook": {
    "enabled": false
